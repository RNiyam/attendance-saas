    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/auth/signup",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organizationName\": \"Acme Demo\",\n  \"organizationSlug\": \"{{organizationSlug}}\",\n  \"ownerEmail\": \"owner@example.com\",\n  \"password\": \"password123\",\n  \"ownerDisplayName\": \"Owner\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const c = pm.response.code;",
                  "if (c !== 200 && c !== 201) return;",
                  "try {",
                  "  const j = pm.response.json();",
                  "  if (j.accessToken) {",
                  "    pm.environment.set('accessToken', j.accessToken);",
                  "    pm.collectionVariables.set('accessToken', j.accessToken);",
                  "  }",
                  "  if (j.refreshToken) {",
                  "    pm.environment.set('refreshToken', j.refreshToken);",
                  "    pm.collectionVariables.set('refreshToken', j.refreshToken);",
                  "  }",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/auth/login",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organizationSlug\": \"{{organizationSlug}}\",\n  \"email\": \"owner@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const c = pm.response.code;",
                  "if (c !== 200 && c !== 201) return;",
                  "try {",
                  "  const j = pm.response.json();",
                  "  if (j.accessToken) {",
                  "    pm.environment.set('accessToken', j.accessToken);",
                  "    pm.collectionVariables.set('accessToken', j.accessToken);",
                  "  }",
                  "  if (j.refreshToken) {",
                  "    pm.environment.set('refreshToken', j.refreshToken);",
                  "    pm.collectionVariables.set('refreshToken', j.refreshToken);",
                  "  }",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh tokens",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/auth/refresh",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const c = pm.response.code;",
                  "if (c !== 200 && c !== 201) return;",
                  "try {",
                  "  const j = pm.response.json();",
                  "  if (j.accessToken) {",
                  "    pm.environment.set('accessToken', j.accessToken);",
                  "    pm.collectionVariables.set('accessToken', j.accessToken);",
                  "  }",
                  "  if (j.refreshToken) {",
                  "    pm.environment.set('refreshToken', j.refreshToken);",
                  "    pm.collectionVariables.set('refreshToken', j.refreshToken);",
                  "  }",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
